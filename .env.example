# ============================================================
# Monitor de Movimentações Processuais — Variáveis de Ambiente
# Copie este arquivo para ".env" e preencha os valores.
# ============================================================

# ---------- GOOGLE SHEETS ----------
# Credenciais de uma Service Account (Google Cloud Console > IAM > Service Accounts).
# Compartilhe a planilha com o e-mail da service account (permissão de Editor).
GOOGLE_SERVICE_ACCOUNT_EMAIL=monitor@seu-projeto.iam.gserviceaccount.com
# Cole a "private key" exatamente como vem do JSON. Mantenha as aspas.
# Importante: as quebras de linha "\n" devem ser preservadas.
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n"

# ID da planilha (está na URL: docs.google.com/spreadsheets/d/<ESTE_ID>/edit).
GOOGLE_SHEETS_SPREADSHEET_ID=abc123XYZ_para_colar_aqui

# Range a ler. A planilha deve ter 4 colunas:
#   A: Número do Processo | B: Nome do Cliente | C: Data Última Movimentação | D: Sigla do Tribunal
# A linha 1 é considerada cabeçalho; os dados começam na linha 2.
GOOGLE_SHEETS_RANGE=Página1!A:D

# ---------- DATAJUD (API Pública do CNJ) ----------
# Chave pública de acesso, obtida em: https://datajud-wiki.cnj.jus.br/api-publica/acesso/
DATAJUD_API_KEY=cDZHYzlZa0JadVREZDJCendQbXY6SkJlTzNjLV9TRENyQk1RdnFKZGRQdw==
# URL base (raramente muda).
DATAJUD_BASE_URL=https://api-publica.datajud.cnj.jus.br

# ---------- GOOGLE GEMINI (IA) ----------
# Chave de API em: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=sua_chave_aqui
# Modelo a usar. gemini-2.5-flash é o Flash estável/recomendado para ETL.
GEMINI_MODEL=gemini-2.5-flash

# ---------- RUNTIME ----------
# Número de processos processados simultaneamente (paralelismo).
# O Datajud limita a ~2 req/s por IP — manter baixo para evitar Rate Limit.
CONCURRENCY=2

# Expressão cron do agendamento automático (padrão node-cron: min hora dia mês dia-semana).
# Padrão: a cada 30 minutos. Exemplos: "0 * * * *" (a cada hora), "0 8 * * 1-5" (8h em dias úteis).
CRON_EXPRESSION=*/30 * * * *

# Executar o fluxo uma vez imediatamente ao iniciar (true|false), além do cron.
RUN_ON_START=true

# ---------- TELEGRAM (notificação no celular) ----------
# Como obter (passo a passo no README):
#   1. No Telegram, abra o @BotFather, envie /newbot e siga as instruções.
#      Ele devolve um token como: 8123456789:AAH-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
#   2. Inicie uma conversa com o SEU bot (criado) e envie qualquer mensagem.
#   3. Descubra seu chat_id acessando (no navegador, troque <TOKEN> pelo seu token):
#      https://api.telegram.org/bot<TOKEN>/getUpdates   -> veja "chat":{"id": 123456789}
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ---------- ALERTAS (opcional) ----------
# Webhook para receber o alerta (ex.: Slack, Discord, n8n). Se vazio, só usa console.log.
ALERT_WEBHOOK_URL=
